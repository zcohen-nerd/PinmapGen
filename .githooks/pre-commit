#!/bin/bash
#
# PinmapGen Pre-commit Hook
#
# Validates staged netlist exports by running the generator against them in
# a temporary directory. The commit is blocked if generation fails, so broken
# netlists never land. Nothing is staged automatically — the root-level
# pinmaps/ and firmware/ outputs are gitignored scratch artifacts.

set -e

echo "PinmapGen pre-commit hook running..."

# Collect staged CSV netlists under hardware/exports/
CHANGED_CSVS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^hardware/exports/.*\.csv$' || true)

if [ -z "$CHANGED_CSVS" ]; then
    echo "No netlist changes detected, skipping validation."
    exit 0
fi

if ! command -v python >/dev/null 2>&1; then
    echo "ERROR: Python not found - cannot validate netlists."
    echo "       Install Python or commit with --no-verify to skip."
    exit 1
fi

TMP_OUT=$(mktemp -d)
trap 'rm -rf "$TMP_OUT"' EXIT

FAILED=0
for csv_file in $CHANGED_CSVS; do
    echo "Validating $csv_file..."

    # Detect MCU type from filename or default to rp2040
    mcu_type="rp2040"
    if [[ "$csv_file" == *"stm32"* ]]; then
        mcu_type="stm32g0"
    elif [[ "$csv_file" == *"esp32s3"* ]]; then
        mcu_type="esp32s3"
    elif [[ "$csv_file" == *"esp32c3"* ]]; then
        mcu_type="esp32c3"
    elif [[ "$csv_file" == *"esp32"* ]]; then
        mcu_type="esp32"
    elif [[ "$csv_file" == *"nrf52"* ]]; then
        mcu_type="nrf52840"
    fi

    out_dir="$TMP_OUT/$(basename "$csv_file" .csv)"
    if python -m tools.pinmapgen.cli \
        --csv "$csv_file" \
        --mcu "$mcu_type" \
        --mcu-ref U1 \
        --out-root "$out_dir" \
        --mermaid; then
        echo "  OK ($mcu_type)"
    else
        echo "  FAILED ($mcu_type) - fix the netlist or run the CLI manually to debug"
        FAILED=1
    fi
done

if [ "$FAILED" -ne 0 ]; then
    echo "Pre-commit validation failed. Commit aborted."
    exit 1
fi

echo "All changed netlists generate cleanly."
